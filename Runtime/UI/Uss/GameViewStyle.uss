.view-hidden {
    width: 100%;
    height: 100%;
    transition-property: scale, opacity;
    transition-duration: 0.5s, 0.5s;
    transition-timing-function: ease-out-back, ease-out-back;
    opacity: 0;
    scale: 0 0;
}

.view-visible {
    opacity: 1;
    scale: 1 1;
}

.game__container {
    width: 100%;
    height: 100%;
    flex-grow: 0;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    align-self: auto;
}
