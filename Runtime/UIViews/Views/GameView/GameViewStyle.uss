.view-hidden {
    scale: 0 0;
}

.view-visible {
    scale: 1 1;
}

.game__container {
    width: 100%;
    height: 100%;
    flex-grow: 0;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    align-self: auto;
    transition-timing-function: ease-out;
    transition-duration: 0.5s;
    transition-property: scale;
}
